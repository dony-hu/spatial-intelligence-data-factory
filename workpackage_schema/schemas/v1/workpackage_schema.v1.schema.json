{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spatial-intelligence-data-factory/workpackage_schema/workpackage_schema.v1.schema.json",
  "title": "WorkpackageBlueprintV1",
  "description": "Factory Agent-LLM-治理Runtime 之间的工作包协议（v1）。用于生成、校验、发布与运行阶段的统一结构。",
  "$comment": "JSON 不支持 // 注释；本协议使用 description/$comment 做字段级语义说明。顶层 required 字段为最小闭环，缺失即 schema 不通过。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "workpackage",
    "architecture_context",
    "io_contract",
    "api_plan",
    "execution_plan",
    "scripts",
    "skills"
  ],
  "$defs": {
    "binding": {
      "type": "object",
      "description": "输入输出绑定定义。用于把数据格式与读写协议拆开表达，支撑生成可直接运行的脚本。",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "role",
        "mode",
        "format",
        "delivery_semantics",
        "resource"
      ],
      "properties": {
        "binding_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,80}$",
          "description": "绑定唯一标识。供 steps 与 scripts 引用。"
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "evidence",
            "control"
          ],
          "description": "绑定角色。"
        },
        "mode": {
          "type": "string",
          "enum": [
            "file",
            "database",
            "http",
            "kafka",
            "stream"
          ],
          "description": "协议/介质类型。"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "jsonl",
            "csv",
            "parquet",
            "avro",
            "none"
          ],
          "description": "序列化格式。database 模式可使用 none。"
        },
        "delivery_semantics": {
          "type": "string",
          "enum": [
            "batch",
            "request_response",
            "at_least_once",
            "exactly_once"
          ],
          "description": "交付语义。"
        },
        "resource": {
          "type": "object",
          "description": "具体资源定位信息，按 mode 分支约束。"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "file"
              }
            }
          },
          "then": {
            "properties": {
              "resource": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "path_env": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]{2,64}$"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "database"
              }
            }
          },
          "then": {
            "properties": {
              "resource": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "engine",
                  "dsn_env",
                  "schema",
                  "table"
                ],
                "properties": {
                  "engine": {
                    "type": "string",
                    "enum": [
                      "postgresql"
                    ]
                  },
                  "dsn_env": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]{2,64}$"
                  },
                  "schema": {
                    "type": "string"
                  },
                  "table": {
                    "type": "string"
                  },
                  "write_mode": {
                    "type": "string",
                    "enum": [
                      "append",
                      "upsert",
                      "replace"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "http"
              }
            }
          },
          "then": {
            "properties": {
              "resource": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "base_url",
                  "path",
                  "method"
                ],
                "properties": {
                  "base_url": {
                    "type": "string",
                    "pattern": "^https?://.+"
                  },
                  "path": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "GET",
                      "POST",
                      "PUT"
                    ]
                  },
                  "auth_env": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]{2,64}$"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "kafka"
              }
            }
          },
          "then": {
            "properties": {
              "resource": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "brokers_env",
                  "topic"
                ],
                "properties": {
                  "brokers_env": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]{2,64}$"
                  },
                  "topic": {
                    "type": "string"
                  },
                  "group_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "stream"
              }
            }
          },
          "then": {
            "properties": {
              "resource": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "engine",
                  "stream_name"
                ],
                "properties": {
                  "engine": {
                    "type": "string"
                  },
                  "stream_name": {
                    "type": "string"
                  },
                  "consumer_group": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      ]
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "workpackage_schema.v1",
      "description": "协议版本号。运行时必须严格匹配，防止消费者/生产者结构漂移。"
    },
    "mode": {
      "type": "string",
      "enum": [
        "blueprint_mode"
      ],
      "description": "协议模式。v1 仅允许 blueprint_mode 作为最终落盘格式。"
    },
    "workpackage": {
      "type": "object",
      "description": "工作包元信息：标识、范围、责任人、优先级与验收标准。",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "objective",
        "scope",
        "owner",
        "priority",
        "status",
        "acceptance_criteria"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
          "description": "机器可读ID，建议 kebab-case。"
        },
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "description": "工作包显示名称，供页面与审计日志展示。"
        },
        "version": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+\\.\\d+$",
          "description": "语义化版本号，必须以 v 开头。"
        },
        "objective": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "业务目标陈述，需覆盖输入、处理、输出与验收价值。"
        },
        "scope": {
          "type": "object",
          "description": "能力边界定义。in_scope 为本工作包职责，out_of_scope 为排除项。",
          "additionalProperties": false,
          "required": [
            "in_scope",
            "out_of_scope"
          ],
          "properties": {
            "in_scope": {
              "type": "array",
              "description": "本工作包必须落地的能力范围。",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 200,
                "description": "单条 in-scope 能力项。"
              }
            },
            "out_of_scope": {
              "type": "array",
              "description": "明确不在本次交付内的能力，避免需求蔓延。",
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 200,
                "description": "单条 out-of-scope 能力项。"
              }
            }
          }
        },
        "owner": {
          "type": "object",
          "description": "责任归属，用于人工门禁与故障追踪。",
          "additionalProperties": false,
          "required": [
            "team",
            "role"
          ],
          "properties": {
            "team": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100,
              "description": "负责团队名称。"
            },
            "role": {
              "type": "string",
              "enum": [
                "pm",
                "architect",
                "dev",
                "qa",
                "ops"
              ],
              "description": "主责角色。"
            },
            "contact": {
              "type": "string",
              "maxLength": 100,
              "description": "可选联系方式（邮箱/IM/值班别名）。"
            }
          }
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ],
          "description": "优先级。P0最高。"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "aligned",
            "ready_for_generate",
            "generated"
          ],
          "description": "工作包设计状态机。"
        },
        "acceptance_criteria": {
          "type": "array",
          "description": "可验证的验收条件清单。用于发布门禁与自动化测试断言。",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300,
            "description": "单条验收标准。"
          }
        }
      }
    },
    "architecture_context": {
      "type": "object",
      "description": "数据治理工厂架构上下文与运行环境约束。",
      "additionalProperties": false,
      "required": [
        "factory_architecture",
        "runtime_env"
      ],
      "properties": {
        "factory_architecture": {
          "type": "object",
          "description": "与工作包执行相关的分层架构、职责及数据流。建议包含 layers/lifecycle/data_flow。"
        },
        "runtime_env": {
          "type": "object",
          "description": "执行环境基线（Python/数据库/网络与fallback策略）。建议包含 docker-only PG 约束。"
        }
      }
    },
    "io_contract": {
      "type": "object",
      "description": "输入输出契约。用于LLM对齐、运行时校验、脚本生成及结果验收。",
      "additionalProperties": false,
      "required": [
        "input_schema",
        "output_schema",
        "input_bindings",
        "output_bindings"
      ],
      "properties": {
        "input_schema": {
          "type": "object",
          "description": "输入结构定义（建议包含 request_id/raw_text）。必须可被运行时直接校验。"
        },
        "output_schema": {
          "type": "object",
          "description": "输出结构定义（建议包含 normalization/entity_parsing/address_validation/spatial_graph）。需与 dryrun 报告字段一致。"
        },
        "input_bindings": {
          "type": "array",
          "description": "输入绑定列表，定义输入从哪里读、用什么协议读。",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/binding"
          }
        },
        "output_bindings": {
          "type": "array",
          "description": "输出绑定列表，定义结果往哪里写、用什么协议写。",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/binding"
          }
        }
      }
    },
    "api_plan": {
      "type": "object",
      "description": "API 绑定计划：已注册可用能力 + 缺失能力扩展方案。",
      "additionalProperties": false,
      "required": [
        "registered_apis_used",
        "missing_apis"
      ],
      "properties": {
        "registered_apis_used": {
          "type": "array",
          "description": "可信数据Hub中已注册并被本工作包实际使用的 API 列表。",
          "items": {
            "type": "object",
            "description": "单个已注册 API 的绑定信息。",
            "properties": {
              "source_id": {
                "type": "string",
                "description": "数据源ID（来自 TrustHub）。"
              },
              "interface_id": {
                "type": "string",
                "description": "接口ID。"
              },
              "name": {
                "type": "string",
                "description": "接口名称。"
              },
              "base_url": {
                "type": "string",
                "description": "接口基地址。"
              },
              "method": {
                "type": "string",
                "description": "HTTP方法。"
              },
              "pipeline_stage": {
                "type": "string",
                "description": "绑定到治理流水线的阶段。"
              },
              "request_mapping": {
                "type": "object",
                "description": "请求字段映射（工作包字段 -> API 参数）。"
              },
              "response_mapping": {
                "type": "object",
                "description": "响应字段映射（API 返回 -> 工作包字段）。"
              }
            }
          }
        },
        "missing_apis": {
          "type": "array",
          "description": "已注册能力不足时的补齐计划。必须提供 key 需求与注册方案。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "description": "单个缺失能力条目。",
            "required": [
              "name",
              "endpoint",
              "reason",
              "requires_key",
              "api_key_env",
              "register_plan"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 2,
                "maxLength": 120,
                "description": "缺失能力名称。"
              },
              "endpoint": {
                "type": "string",
                "pattern": "^https?://.+",
                "description": "候选外部 API 端点。"
              },
              "reason": {
                "type": "string",
                "minLength": 5,
                "maxLength": 300,
                "description": "为何当前已注册 API 不足。"
              },
              "requires_key": {
                "type": "boolean",
                "description": "是否需要用户提供外部密钥。"
              },
              "api_key_env": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]{2,64}$",
                "description": "外部密钥环境变量名。"
              },
              "register_plan": {
                "type": "object",
                "description": "注册到 TrustHub 的计划与状态（如 pending_key/active）。",
                "properties": {
                  "target": {
                    "type": "string",
                    "description": "注册目标系统，建议 trust_hub。"
                  },
                  "tool_type": {
                    "type": "string",
                    "description": "注册对象类型（api/script）。"
                  },
                  "status_on_register": {
                    "type": "string",
                    "description": "注册后的状态（pending_key 或 active）。"
                  }
                }
              }
            }
          }
        }
      }
    },
    "execution_plan": {
      "type": "object",
      "description": "执行编排：步骤、人工门禁、失败处理策略。",
      "additionalProperties": false,
      "required": [
        "steps",
        "gates",
        "failure_handling"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "description": "执行步骤清单（至少 1 步）。建议覆盖 confirm/generate/dryrun/publish/upload。",
          "minItems": 1,
          "items": {
            "type": "object",
            "description": "单个执行步骤定义。",
            "properties": {
              "step_id": {
                "type": "string",
                "description": "步骤编号（例如 S01）。"
              },
              "name": {
                "type": "string",
                "description": "步骤名称。"
              },
              "stage": {
                "type": "string",
                "description": "生命周期阶段。"
              },
              "inputs": {
                "type": "array",
                "description": "该步骤输入依赖。",
                "items": {
                  "type": "string",
                  "description": "单条输入引用。"
                }
              },
              "outputs": {
                "type": "array",
                "description": "该步骤产出。",
                "items": {
                  "type": "string",
                  "description": "单条输出引用。"
                }
              },
              "input_bindings": {
                "type": "array",
                "description": "该步骤直接消费的输入绑定 ID。",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{2,80}$"
                }
              },
              "output_bindings": {
                "type": "array",
                "description": "该步骤直接产出的输出绑定 ID。",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{2,80}$"
                }
              },
              "timeout_sec": {
                "type": "integer",
                "description": "该步骤超时时间（秒）。"
              },
              "retry": {
                "type": "object",
                "description": "重试策略对象。"
              }
            }
          }
        },
        "gates": {
          "type": "object",
          "description": "人工门禁状态。用于阻断未确认流程。",
          "required": [
            "confirm_generate",
            "confirm_dryrun_result",
            "confirm_publish"
          ],
          "properties": {
            "confirm_generate": {
              "type": "boolean",
              "description": "是否已通过生成门禁。未确认时禁止进入 packaged。"
            },
            "confirm_dryrun_result": {
              "type": "boolean",
              "description": "是否已确认 dryrun 结果。"
            },
            "confirm_publish": {
              "type": "boolean",
              "description": "是否已通过发布门禁。未确认时禁止进入 submitted。"
            }
          }
        },
        "failure_handling": {
          "type": "object",
          "description": "异常处理策略。schema 不通过时应继续与 LLM 互动直到通过。",
          "required": [
            "on_schema_mismatch",
            "on_api_failure",
            "on_dependency_missing"
          ],
          "properties": {
            "on_schema_mismatch": {
              "type": "string",
              "enum": [
                "continue_llm_interaction_until_valid"
              ],
              "description": "固定策略：不阻塞，持续互动修复 schema。"
            },
            "on_api_failure": {
              "type": "string",
              "const": "block_error_no_fallback",
              "description": "API 调用失败处理策略。v1 强制 no-fallback：失败即阻断并返回错误。"
            },
            "on_dependency_missing": {
              "type": "string",
              "description": "依赖缺失处理策略（应产出脚本与 key 模板）。"
            }
          }
        }
      }
    },
    "scripts": {
      "type": "array",
      "description": "可执行脚本清单。用于处理外部依赖、数据处理与运行落盘。",
      "minItems": 1,
      "items": {
        "type": "object",
        "description": "单个可执行脚本定义。",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "runtime",
          "entry",
          "dependencies",
          "consumes",
          "produces"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{2,80}\\.py$",
            "description": "脚本文件名，必须为 python 文件。"
          },
          "purpose": {
            "type": "string",
            "minLength": 5,
            "maxLength": 300,
            "description": "脚本业务目的，需可映射到 execution_plan 步骤。"
          },
          "runtime": {
            "type": "string",
            "enum": [
              "python3"
            ],
            "description": "脚本运行时。v1 固定 python3。"
          },
          "entry": {
            "type": "string",
            "pattern": "^python\\s+scripts/[a-z0-9_]+\\.py(\\s+.*)?$",
            "description": "执行命令入口，统一约束到 scripts/ 目录。"
          },
          "dependencies": {
            "type": "array",
            "description": "脚本依赖包列表（用于环境准备与复现实验）。",
            "items": {
              "type": "string",
              "description": "单条依赖包定义（建议带版本约束）。"
            }
          },
          "consumes": {
            "type": "array",
            "description": "脚本直接消费的 binding_id 列表。",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{2,80}$"
            }
          },
          "produces": {
            "type": "array",
            "description": "脚本直接产出的 binding_id 列表。",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{2,80}$"
            }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "工作包内置技能清单。skills 是工作包的一部分，运行时通过该清单加载能力说明。",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "name",
          "path",
          "purpose"
        ],
        "properties": {
          "skill_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$",
            "description": "技能唯一标识，建议 snake_case 或 kebab-case。"
          },
          "name": {
