{
  "schema_version": "workpackage_schema.v1",
  "mode": "blueprint_mode",
  "workpackage": {
    "id": "address-governance-records-spatial",
    "name": "address_governance_records_spatial",
    "version": "v1.0.2",
    "objective": "完成地址标准化、地址验真、空间实体拆分，并输出可落库的空间图谱数据与质量报告。",
    "scope": {
      "in_scope": [
        "normalization",
        "entity_parsing",
        "address_validation",
        "spatial_graph"
      ],
      "out_of_scope": []
    },
    "owner": {
      "team": "governance-factory",
      "role": "dev",
      "contact": "factory-oncall"
    },
    "priority": "P1",
    "status": "aligned",
    "acceptance_criteria": [
      "records[] 每条包含 normalization/entity_parsing/address_validation",
      "spatial_graph 输出 nodes/edges/metrics/failed_row_refs/build_status"
    ]
  },
  "architecture_context": {
    "factory_architecture": {
      "layers": [
        "Agent会话编排层",
        "可信数据Hub层",
        "工作包执行层",
        "运行态可观测层"
      ],
      "workpackage_lifecycle": [
        "requirements_confirm",
        "generate",
        "dryrun",
        "publish",
        "runtime_upload"
      ]
    },
    "runtime_env": {
      "python": "3.11",
      "os": "linux",
      "network": "允许访问可信数据Hub与已备案外部API",
      "constraints": {
        "no_fallback": true,
        "no_mock": true,
        "no_workground": true,
        "requires_real_llm": true
      },
      "env_vars_required": [
        "FENGTU_APP_KEY",
        "FENGTU_APP_SECRET",
        "AMAP_API_KEY",
        "BAIDU_AK"
      ]
    }
  },
  "io_contract": {
    "input_schema": {
      "type": "object",
      "required": [
        "batch_id",
        "addresses"
      ],
      "properties": {
        "batch_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{6,64}$"
        },
        "callback_url": {
          "type": "string",
          "format": "uri"
        },
        "addresses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "raw_address"
            ],
            "properties": {
              "record_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]{1,64}$"
              },
              "raw_address": {
                "type": "string",
                "minLength": 2,
                "maxLength": 500
              },
              "city_hint": {
                "type": "string"
              },
              "lat_hint": {
                "type": "number",
                "minimum": -90,
                "maximum": 90
              },
              "lng_hint": {
                "type": "number",
                "minimum": -180,
                "maximum": 180
              },
              "biz_tag": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "output_schema": {
      "type": "object",
      "required": [
        "batch_id",
        "records",
        "spatial_graph",
        "quality_report"
      ],
      "properties": {
        "batch_id": {
          "type": "string"
        },
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "standardized_address",
              "real_check",
              "entities"
            ],
            "properties": {
              "record_id": {
                "type": "string"
              },
              "standardized_address": {
                "type": "object",
                "properties": {
                  "full_text": {
                    "type": "string"
                  },
                  "province": {
                    "type": "string"
                  },
                  "city": {
                    "type": "string"
                  },
                  "district": {
                    "type": "string"
                  },
                  "township": {
                    "type": "string"
                  },
                  "road": {
                    "type": "string"
                  },
                  "house_no": {
                    "type": "string"
                  },
                  "adcode": {
                    "type": "string"
                  },
                  "location": {
                    "type": "object",
                    "properties": {
                      "lat": {
                        "type": "number"
                      },
                      "lng": {
                        "type": "number"
                      }
                    },
                    "required": [
                      "lat",
                      "lng"
                    ]
                  }
                },
                "required": [
                  "full_text"
                ]
              },
              "real_check": {
                "type": "object",
                "required": [
                  "is_real",
                  "score",
                  "code"
                ],
                "properties": {
                  "is_real": {
                    "type": "boolean"
                  },
                  "score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              },
              "entities": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "entity_type",
                    "entity_name"
                  ],
                  "properties": {
                    "entity_type": {
                      "type": "string",
                      "enum": [
                        "province",
                        "city",
                        "district",
                        "street",
                        "poi",
                        "building",
                        "community",
                        "room"
                      ]
                    },
                    "entity_name": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "adcode": {
                      "type": "string"
                    }
                  }
                }
              },
              "api_trace": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "api": {
                      "type": "string"
                    },
                    "status_code": {
                      "type": "integer"
                    },
                    "latency_ms": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "spatial_graph": {
          "type": "object",
          "required": [
            "nodes",
            "edges"
          ],
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "node_id",
                  "node_type",
                  "name"
                ],
                "properties": {
                  "node_id": {
                    "type": "string"
                  },
                  "node_type": {
                    "type": "string",
                    "enum": [
                      "ADMIN",
                      "POI",
                      "ADDRESS",
                      "BUILDING",
                      "COMMUNITY"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "adcode": {
                    "type": "string"
                  },
                  "location": {
                    "type": "object",
                    "properties": {
                      "lat": {
                        "type": "number"
                      },
                      "lng": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "from",
                  "to",
                  "relation"
                ],
                "properties": {
                  "from": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string"
                  },
                  "relation": {
                    "type": "string",
                    "enum": [
                      "LOCATED_IN",
                      "NEARBY",
                      "BELONGS_TO",
                      "ALIAS_OF"
                    ]
                  },
                  "weight": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "quality_report": {
          "type": "object",
          "required": [
            "total",
            "standardize_success",
            "real_check_pass",
            "entity_split_success",
            "graph_node_count",
            "graph_edge_count"
          ],
          "properties": {
            "total": {
              "type": "integer"
            },
            "standardize_success": {
              "type": "integer"
            },
            "real_check_pass": {
              "type": "integer"
            },
            "entity_split_success": {
              "type": "integer"
            },
            "graph_node_count": {
              "type": "integer"
            },
            "graph_edge_count": {
              "type": "integer"
            },
            "error_codes": {
              "type": "object",
              "additionalProperties": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  },
  "api_plan": {
    "registered_apis_used": [
      {
        "source_id": "fengtu",
        "interface_id": "address_standardize",
        "method": "POST"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_real_check",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_resolve_l5",
        "method": "POST"
      },
      {
        "source_id": "fengtu",
        "interface_id": "geocode",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "reverse_geocode",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_type_identify",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_aoi_keyword",
        "method": "POST"
      }
    ],
    "missing_apis": [
      {
        "name": "行政区划标准码校验",
        "endpoint": "https://restapi.amap.com/v3/config/district",
        "reason": "已注册接口缺少权威行政区划层级树与最新adcode映射拉平能力，影响图谱ADMIN节点标准一致性。",
        "requires_key": true,
        "api_key_env": "AMAP_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      },
      {
        "name": "POI详情补全",
        "endpoint": "https://api.map.baidu.com/place/v2/detail",
        "reason": "空间实体拆分后需POI详情字段（名称别名、类别、坐标置信）增强图谱节点质量，现有注册API不足。",
        "requires_key": true,
        "api_key_env": "BAIDU_AK",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      },
      {
        "name": "空间实体拆分API",
        "endpoint": "https://api.external.example.com/entity/parsing",
        "reason": "补齐空间实体拆分能力",
        "requires_key": true,
        "api_key_env": "ENTITY_PARSING_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      },
      {
        "name": "空间图谱构建API",
        "endpoint": "https://api.external.example.com/spatial/graph/build",
        "reason": "补齐空间图谱输出能力",
        "requires_key": true,
        "api_key_env": "SPATIAL_GRAPH_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      }
    ]
  },
  "execution_plan": {
    "steps": [
      {
        "step_id": "S01",
        "name": "step-1",
        "stage": "generate",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S02",
        "name": "step-2",
        "stage": "dryrun",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S03",
        "name": "step-3",
        "stage": "publish",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S04",
        "name": "step-4",
        "stage": "runtime_upload",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      }
    ],
    "gates": {
      "confirm_generate": false,
      "confirm_dryrun_result": false,
      "confirm_publish": false
    },
    "failure_handling": {
      "on_schema_mismatch": "continue_llm_interaction_until_valid",
      "on_api_failure": "block_error_no_fallback",
      "on_dependency_missing": "ask_user_for_key_and_register"
    }
  },
  "scripts": [
    {
      "name": "address_pipeline.py",
      "purpose": "批量执行地址标准化、地址验真、五级拆分与坐标补全",
      "runtime": "python3",
      "entry": "python scripts/address_pipeline.py --input ./data/input.json --out ./out/records.json",
      "dependencies": [
        "requests>=2.31.0",
        "pydantic>=2.6.0"
      ]
    },
    {
      "name": "spatial_graph_builder.py",
      "purpose": "从records构建空间图谱nodes/edges并输出图谱文件",
      "runtime": "python3",
      "entry": "python scripts/spatial_graph_builder.py --records ./out/records.json --out ./out/spatial_graph.json",
      "dependencies": [
        "networkx>=3.2.1"
      ]
    },
    {
      "name": "dryrun_validate.py",
      "purpose": "执行dry run质量校验并生成质量报告",
      "runtime": "python3",
      "entry": "python scripts/dryrun_validate.py --records ./out/records.json --graph ./out/spatial_graph.json --out ./out/quality_report.json",
      "dependencies": [
        "pandas>=2.2.0"
      ]
    },
    {
      "name": "publish_package.py",
      "purpose": "将工作包产物发布到工厂并写入版本元数据",
      "runtime": "python3",
      "entry": "python scripts/publish_package.py --name address-governance-records-spatial --version 1.0.2 --dir ./out",
      "dependencies": [
        "requests>=2.31.0"
      ]
    },
    {
      "name": "fetch_wp_d622eada.py",
      "purpose": "调用外部API补齐能力：行政区划标准码校验",
      "runtime": "python3",
      "entry": "python scripts/fetch_wp_d622eada.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    },
    {
      "name": "fetch_poi.py",
      "purpose": "调用外部API补齐能力：POI详情补全",
      "runtime": "python3",
      "entry": "python scripts/fetch_poi.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    },
    {
      "name": "fetch_api.py",
      "purpose": "调用外部API补齐能力：空间实体拆分API",
      "runtime": "python3",
      "entry": "python scripts/fetch_api.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    }
  ],
  "skills": [
    {
      "skill_id": "nanobot_workpackage_schema_orchestrator",
      "name": "nanobot 工作包协议编排",
      "path": "skills/nanobot_workpackage_schema_orchestrator.md",
      "purpose": "引导用户补齐工作包 schema 并持续收敛",
      "required": true
    },
    {
      "skill_id": "opencode_workpackage_builder_guardrails",
      "name": "opencode 工作包构建护栏",
      "path": "skills/opencode_workpackage_builder_guardrails.md",
      "purpose": "生成可执行工件并遵循 no-fallback/no-mock 约束",
      "required": true
    }
  ]
}