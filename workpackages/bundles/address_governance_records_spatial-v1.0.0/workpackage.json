    "gates": {
      "confirm_generate": false,
      "confirm_dryrun_result": false,
      "confirm_publish": false
    },
    "failure_handling": {
      "on_schema_mismatch": "continue_llm_interaction_until_valid",
      "on_api_failure": "block_error_no_fallback",
      "on_dependency_missing": "ask_user_for_key_and_register"
    }
  },
  "scripts": [
    {
      "name": "run_pipeline.py",
      "purpose": "主执行脚本：读取addresses[]并串联标准化、解析、编码、复核、构图",
      "runtime": "python3",
      "entry": "python run_pipeline.py --input ./input.json --out_records ./records.json --out_graph ./spatial_graph.json",
      "dependencies": [
        "requests>=2.31.0",
        "pydantic>=2.6.0",
        "tenacity>=8.2.0",
        "networkx>=3.2.1"
      ]
    },
    {
      "name": "dryrun_1000-sh.py",
      "purpose": "执行1000条样本压测与质量校验",
      "runtime": "python3",
      "entry": "bash dryrun_1000.sh ./samples_1000.json",
      "dependencies": []
    },
    {
      "name": "sla_probe.py",
      "purpose": "接口SLA探测：QPS、P95、可用性与超时统计",
      "runtime": "python3",
      "entry": "python sla_probe.py --qps 50 --timeout_ms 2000 --duration_sec 300",
      "dependencies": [
        "httpx>=0.27.0",
        "pandas>=2.2.0"
      ]
    },
    {
      "name": "publish_workpackage-sh.py",
      "purpose": "发布工作包并回传runtime_upload元数据",
      "runtime": "python3",
      "entry": "bash publish_workpackage.sh wp_address_governance_records_spatial 1.0.0",
      "dependencies": []
    },
    {
      "name": "fetch_wp_a8892a62.py",
      "purpose": "调用外部API补齐能力：主体三要素核验",
      "runtime": "python3",
      "entry": "python scripts/fetch_wp_a8892a62.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    },
    {
      "name": "fetch_wp_3e4d7033.py",
      "purpose": "调用外部API补齐能力：风险名单命中查询",
      "runtime": "python3",
      "entry": "python scripts/fetch_wp_3e4d7033.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    },
    {
      "name": "fetch_api.py",
      "purpose": "调用外部API补齐能力：空间图谱构建API",
