{
  "schema_version": "workpackage_schema.v1",
  "mode": "blueprint_mode",
  "workpackage": {
    "id": "address-governance-records-spatial",
    "name": "address-governance-records-spatial",
    "version": "v1.0.1",
    "objective": "对输入地址批次执行地址标准化、地址验真、空间实体拆分，并输出可查询的空间图谱（nodes/edges）及质量报告。",
    "scope": {
      "in_scope": [
        "normalization",
        "entity_parsing",
        "address_validation",
        "spatial_graph"
      ],
      "out_of_scope": []
    },
    "owner": {
      "team": "governance-factory",
      "role": "dev",
      "contact": "factory-oncall"
    },
    "priority": "P1",
    "status": "aligned",
    "acceptance_criteria": [
      "records[] 每条包含 normalization/entity_parsing/address_validation",
      "spatial_graph 输出 nodes/edges/metrics/failed_row_refs/build_status"
    ]
  },
  "architecture_context": {
    "factory_architecture": {
      "layers": [
        "Agent会话编排层",
        "可信数据Hub层",
        "工作包执行层",
        "运行态可观测层"
      ],
      "workpackage_lifecycle": [
        "requirements_confirm",
        "generate",
        "dryrun",
        "publish",
        "runtime_upload"
      ]
    },
    "runtime_env": {
      "python_version": "3.10",
      "network": "可出网访问已注册API与待注册外部API",
      "constraints": {
        "no_fallback": true,
        "no_mock": true,
        "no_workground": true,
        "requires_real_llm": true
      },
      "env_vars_required": [
        "FENGTU_GROUP_A_KEY",
        "FENGTU_GROUP_B_KEY",
        "CALLBACK_URL",
        "WHITELIST_IP"
      ]
    }
  },
  "io_contract": {
    "input_schema": {
      "type": "object",
      "required": [
        "batch_id",
        "addresses"
      ],
      "properties": {
        "batch_id": {
          "type": "string",
          "description": "批次ID"
        },
        "callback_url": {
          "type": "string",
          "format": "uri"
        },
        "addresses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "raw_address"
            ],
            "properties": {
              "record_id": {
                "type": "string"
              },
              "raw_address": {
                "type": "string"
              },
              "city_hint": {
                "type": "string"
              },
              "lat": {
                "type": "number"
              },
              "lng": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "output_schema": {
      "type": "object",
      "required": [
        "batch_id",
        "records",
        "spatial_graph",
        "metrics"
      ],
      "properties": {
        "batch_id": {
          "type": "string"
        },
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "raw_address",
              "standardized_address",
              "real_check",
              "entities"
            ],
            "properties": {
              "record_id": {
                "type": "string"
              },
              "raw_address": {
                "type": "string"
              },
              "standardized_address": {
                "type": "object",
                "properties": {
                  "province": {
                    "type": "string"
                  },
                  "city": {
                    "type": "string"
                  },
                  "district": {
                    "type": "string"
                  },
                  "town": {
                    "type": "string"
                  },
                  "road": {
                    "type": "string"
                  },
                  "house_number": {
                    "type": "string"
                  },
                  "full_address": {
                    "type": "string"
                  },
                  "adcode": {
                    "type": "string"
                  },
                  "location": {
                    "type": "object",
                    "properties": {
                      "lat": {
                        "type": "number"
                      },
                      "lng": {
                        "type": "number"
                      }
                    }
                  }
                }
              },
              "real_check": {
                "type": "object",
                "properties": {
                  "is_real": {
                    "type": "boolean"
                  },
                  "score": {
                    "type": "number"
                  },
                  "reason_code": {
                    "type": "string"
                  }
                }
              },
              "entities": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "entity_type",
                    "entity_name"
                  ],
                  "properties": {
                    "entity_type": {
                      "type": "string",
                      "enum": [
                        "province",
                        "city",
                        "district",
                        "town",
                        "road",
                        "poi",
                        "building",
                        "house_number"
                      ]
                    },
                    "entity_name": {
                      "type": "string"
                    },
                    "entity_code": {
                      "type": "string"
                    }
                  }
                }
              },
              "status": {
                "type": "string",
                "enum": [
                  "success",
                  "partial_success",
                  "failed"
                ]
              },
              "error_code": {
                "type": "string"
              }
            }
          }
        },
        "spatial_graph": {
          "type": "object",
          "required": [
            "nodes",
            "edges"
          ],
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "node_id",
                  "node_type",
                  "name"
                ],
                "properties": {
                  "node_id": {
                    "type": "string"
                  },
                  "node_type": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "adcode": {
                    "type": "string"
                  },
                  "centroid": {
                    "type": "object",
                    "properties": {
                      "lat": {
                        "type": "number"
                      },
                      "lng": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "src",
                  "dst",
                  "relation"
                ],
                "properties": {
                  "src": {
                    "type": "string"
                  },
                  "dst": {
                    "type": "string"
                  },
                  "relation": {
                    "type": "string",
                    "enum": [
                      "contains",
                      "located_in",
                      "adjacent_to",
                      "same_as"
                    ]
                  },
                  "weight": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "total": {
              "type": "integer"
            },
            "success_count": {
              "type": "integer"
            },
            "fail_count": {
              "type": "integer"
            },
            "real_hit_rate": {
              "type": "number"
            },
            "avg_latency_ms": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "api_plan": {
    "registered_apis_used": [
      {
        "source_id": "fengtu",
        "interface_id": "address_standardize",
        "name": "地址标准化",
        "method": "POST"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_real_check",
        "name": "地址真实性校验",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_resolve_l5",
        "name": "五级地址解析",
        "method": "POST"
      },
      {
        "source_id": "fengtu",
        "interface_id": "geocode",
        "name": "地理编码",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "reverse_geocode",
        "name": "逆地理编码",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_aoi_keyword",
        "name": "地址AOI聚合",
        "method": "POST"
      }
    ],
    "missing_apis": [
      {
        "name": "行政区边界与邻接关系API",
        "endpoint": "https://restapi.amap.com/v3/config/district",
        "reason": "空间图谱需要构建行政区邻接边(adjacent_to)，当前注册目录缺少边界/邻接查询接口",
        "requires_key": true,
        "api_key_env": "AMAP_WEB_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      },
      {
        "name": "POI详情与父子关系API",
        "endpoint": "https://api.map.baidu.com/place/v2/detail",
        "reason": "空间实体拆分后需补充POI类别、父级区域与标准ID，当前已注册API不含跨源POI详情",
        "requires_key": true,
        "api_key_env": "BAIDU_MAP_AK",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      },
      {
        "name": "空间实体拆分API",
        "endpoint": "https://api.external.example.com/entity/parsing",
        "reason": "补齐空间实体拆分能力",
        "requires_key": true,
        "api_key_env": "ENTITY_PARSING_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      },
      {
        "name": "空间图谱构建API",
        "endpoint": "https://api.external.example.com/spatial/graph/build",
        "reason": "补齐空间图谱输出能力",
        "requires_key": true,
        "api_key_env": "SPATIAL_GRAPH_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      }
    ]
  },
  "execution_plan": {
    "steps": [
      {
        "step_id": "S01",
        "name": "step-1",
        "stage": "phase1_architecture_runtime_alignment",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S02",
        "name": "step-2",
        "stage": "phase2_io_contract_alignment",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S03",
        "name": "step-3",
        "stage": "phase3_api_binding_and_gap_fill",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S04",
        "name": "step-4",
        "stage": "phase4_executable_and_rollout",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      }
    ],
    "gates": {
      "confirm_generate": false,
      "confirm_dryrun_result": false,
      "confirm_publish": false
    },
    "failure_handling": {
      "on_schema_mismatch": "continue_llm_interaction_until_valid",
      "on_api_failure": "block_error_no_fallback",
      "on_dependency_missing": "ask_user_for_key_and_register"
    }
  },
  "scripts": [
    {
      "name": "generate_workpackage.py",
      "purpose": "生成工作包元数据、I/O契约与API绑定配置",
      "runtime": "python3",
      "entry": "python scripts/generate_workpackage.py --name address-governance-records-spatial --version 1.0.1",
      "dependencies": [
        "pydantic",
        "pyyaml"
      ]
    },
    {
      "name": "dryrun_address_pipeline.py",
      "purpose": "执行1000条样本dry run，调用标准化/验真/解析/编码接口并输出records",
      "runtime": "python3",
      "entry": "python scripts/dryrun_address_pipeline.py --input data/addresses_sample_1000.json --output out/records.json --qps 50 --timeout 2",
      "dependencies": [
        "requests",
        "tenacity",
        "pandas"
      ]
    },
    {
      "name": "build_spatial_graph.py",
      "purpose": "基于records构建空间图谱nodes/edges并输出图谱文件",
      "runtime": "python3",
      "entry": "python scripts/build_spatial_graph.py --records out/records.json --graph out/spatial_graph.json",
      "dependencies": [
        "networkx",
        "orjson"
      ]
    },
    {
      "name": "publish_workpackage.py",
      "purpose": "校验dry run结果并发布工作包版本到运行态",
      "runtime": "python3",
      "entry": "python scripts/publish_workpackage.py --name address-governance-records-spatial --version 1.0.1 --records out/records.json --graph out/spatial_graph.json",
      "dependencies": []
    },
    {
      "name": "fetch_api.py",
      "purpose": "调用外部API补齐能力：行政区边界与邻接关系API",
      "runtime": "python3",
      "entry": "python scripts/fetch_api.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    },
    {
      "name": "fetch_poi-api.py",
      "purpose": "调用外部API补齐能力：POI详情与父子关系API",
      "runtime": "python3",
      "entry": "python scripts/fetch_poi-api.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    }
  ],
  "skills": [
    {
      "skill_id": "nanobot_workpackage_schema_orchestrator",
      "name": "nanobot 工作包协议编排",
      "path": "skills/nanobot_workpackage_schema_orchestrator.md",
      "purpose": "引导用户补齐工作包 schema 并持续收敛",
      "required": true
    },
    {
      "skill_id": "opencode_workpackage_builder_guardrails",
      "name": "opencode 工作包构建护栏",
      "path": "skills/opencode_workpackage_builder_guardrails.md",
      "purpose": "生成可执行工件并遵循 no-fallback/no-mock 约束",
      "required": true
    }
  ]
}