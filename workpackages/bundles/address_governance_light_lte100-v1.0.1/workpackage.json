    "gates": {
      "confirm_generate": false,
      "confirm_dryrun_result": false,
      "confirm_publish": false
    },
    "failure_handling": {
      "on_schema_mismatch": "continue_llm_interaction_until_valid",
      "on_api_failure": "block_error_no_fallback",
      "on_dependency_missing": "ask_user_for_key_and_register"
    }
  },
  "scripts": [
    {
      "name": "prepare_input.py",
      "purpose": "输入文件规范化与字段校验，生成符合input_schema的JSON。",
      "runtime": "python3",
      "entry": "python scripts/prepare_input.py --input data/input.csv --output data/input.normalized.json",
      "dependencies": [
        "pandas>=2.0.0",
        "jsonschema>=4.0.0"
      ]
    },
    {
      "name": "run_address_governance.py",
      "purpose": "调用Fengtu与高德API执行地址治理主流程，输出治理结果。",
      "runtime": "python3",
      "entry": "python scripts/run_address_governance.py --input data/input.normalized.json --output data/output.governed.json",
      "dependencies": [
        "requests>=2.31.0",
        "tenacity>=8.2.0",
        "pydantic>=2.0.0"
      ]
    },
    {
      "name": "generate_report.py",
      "purpose": "根据治理结果生成质量报告与问题分布统计。",
      "runtime": "python3",
      "entry": "python scripts/generate_report.py --input data/output.governed.json --report reports/address_governance_report.json",
      "dependencies": [
        "pandas>=2.0.0"
      ]
    },
    {
      "name": "fetch_wp_f5d5b949.py",
      "purpose": "调用外部API补齐能力：行政区划代码权威校验",
      "runtime": "python3",
      "entry": "python scripts/fetch_wp_f5d5b949.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    }
  ],
