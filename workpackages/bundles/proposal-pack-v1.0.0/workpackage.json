{
  "schema_version": "workpackage_schema.v1",
  "mode": "blueprint_mode",
  "workpackage": {
    "id": "proposal-pack",
    "name": "proposal-pack",
    "version": "v1.0.0",
    "objective": "proposal，并输出可观测验收结果",
    "scope": {
      "in_scope": [
        "normalization",
        "entity_parsing",
        "address_validation",
        "spatial_graph"
      ],
      "out_of_scope": []
    },
    "owner": {
      "team": "governance-factory",
      "role": "dev",
      "contact": "factory-oncall"
    },
    "priority": "P1",
    "status": "aligned",
    "acceptance_criteria": [
      "records[] 每条包含 normalization/entity_parsing/address_validation",
      "spatial_graph 输出 nodes/edges/metrics/failed_row_refs/build_status"
    ]
  },
  "architecture_context": {
    "factory_architecture": {
      "layers": [
        "a"
      ]
    },
    "runtime_env": {
      "python": "3.11"
    }
  },
  "io_contract": {
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    }
  },
  "api_plan": {
    "registered_apis_used": [
      {
        "source_id": "fengtu",
        "interface_id": "address_level_judge",
        "name": "地址级别判断",
        "base_url": "https://gis-apis.sf-express.com/iad/api",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_real_check",
        "name": "地址真实性校验",
        "base_url": "https://gis-apis.sf-express.com/opquery/addressRealCheck",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_type_identify",
        "name": "地址类型识别",
        "base_url": "https://gis-apis.sf-express.com/atype/api",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "geocode",
        "name": "地理编码",
        "base_url": "https://gis-apis.sf-express.com/all/api/geocode/geo",
        "method": "GET"
      }
    ],
    "missing_apis": [
      {
        "name": "ext-a",
        "endpoint": "https://ext-a.example.com",
        "reason": "need",
        "requires_key": true,
        "api_key_env": "EXT_A_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      }
    ]
  },
  "execution_plan": {
    "steps": [
      {
        "step_id": "S01",
        "name": "s1",
        "stage": "custom",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      }
    ],
    "gates": {
      "confirm_generate": false,
      "confirm_dryrun_result": false,
      "confirm_publish": false
    },
    "failure_handling": {
      "on_schema_mismatch": "continue_llm_interaction_until_valid",
      "on_api_failure": "block_error_no_fallback",
      "on_dependency_missing": "ask_user_for_key_and_register"
    }
  },
  "scripts": [
    {
      "name": "run_pipeline.py",
      "purpose": "执行脚本 run_pipeline.py",
      "runtime": "python3",
      "entry": "python scripts/run_pipeline.py",
      "dependencies": []
    },
    {
      "name": "fetch_ext-a.py",
      "purpose": "调用外部API补齐能力：ext-a",
      "runtime": "python3",
      "entry": "python scripts/fetch_ext-a.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    }
  ],
  "skills": [
    {
      "skill_id": "nanobot_workpackage_schema_orchestrator",
      "name": "nanobot 工作包协议编排",
      "path": "skills/nanobot_workpackage_schema_orchestrator.md",
      "purpose": "引导用户补齐工作包 schema 并持续收敛",
      "required": true
    },
    {
      "skill_id": "opencode_workpackage_builder_guardrails",
      "name": "opencode 工作包构建护栏",
      "path": "skills/opencode_workpackage_builder_guardrails.md",
      "purpose": "生成可执行工件并遵循 no-fallback/no-mock 约束",
      "required": true
    }
  ]
}