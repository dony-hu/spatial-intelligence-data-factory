{
  "schema_version": "workpackage_schema.v1",
  "mode": "blueprint_mode",
  "workpackage": {
    "id": "wp_address_governance_lightweight_fullcheck",
    "name": "wp_address_governance_lightweight_fullcheck",
    "version": "v1.0.1",
    "objective": "面向<=100条地址数据执行全量地址治理，完成地址标准化、五级解析、真实性校验、类型识别、地理编码与质量问题闭环，按工厂生命周期产出可发布工作包。",
    "scope": {
      "in_scope": [
        "normalization",
        "entity_parsing",
        "address_validation",
        "spatial_graph"
      ],
      "out_of_scope": []
    },
    "owner": {
      "team": "governance-factory",
      "role": "dev",
      "contact": "factory-oncall"
    },
    "priority": "P1",
    "status": "aligned",
    "acceptance_criteria": [
      "records[] 每条包含 normalization/entity_parsing/address_validation",
      "spatial_graph 输出 nodes/edges/metrics/failed_row_refs/build_status"
    ]
  },
  "architecture_context": {
    "factory_architecture": {
      "layers": [
        "Agent会话编排层",
        "可信数据Hub层",
        "工作包执行层",
        "运行态可观测层"
      ],
      "workpackage_lifecycle": [
        "requirements_confirm",
        "generate",
        "dryrun",
        "publish",
        "runtime_upload"
      ]
    },
    "runtime_env": {
      "constraints": {
        "no_fallback": true,
        "no_mock": true,
        "no_workground": true,
        "requires_real_llm": true
      },
      "execution_runtime": "python3.10",
      "network": "可访问已注册Fengtu API与外部补齐API",
      "secrets_env": [
        "FENGTU_APP_KEY",
        "FENGTU_APP_SECRET",
        "AMAP_WEB_API_KEY"
      ]
    }
  },
  "io_contract": {
    "input_schema": {
      "type": "object",
      "required": [
        "task_id",
        "dataset",
        "config"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "dataset": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "raw_address"
            ],
            "properties": {
              "record_id": {
                "type": "string"
              },
              "raw_address": {
                "type": "string",
                "minLength": 3
              },
              "receiver_name": {
                "type": "string"
              },
              "receiver_phone": {
                "type": "string"
              },
              "source_system": {
                "type": "string"
              },
              "province_hint": {
                "type": "string"
              },
              "city_hint": {
                "type": "string"
              },
              "district_hint": {
                "type": "string"
              }
            }
          }
        },
        "config": {
          "type": "object",
          "required": [
            "full_check",
            "quality_rules"
          ],
          "properties": {
            "full_check": {
              "type": "boolean",
              "const": true
            },
            "quality_rules": {
              "type": "array",
              "minItems": 5,
              "maxItems": 8,
              "items": {
                "type": "string",
                "enum": [
                  "completeness",
                  "uniqueness",
                  "format",
                  "enum_validity",
                  "time_logic",
                  "address_authenticity",
                  "address_consistency",
                  "geocode_validity"
                ]
              }
            },
            "dedup_keys": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [
                "raw_address",
                "receiver_phone"
              ]
            }
          }
        }
      }
    },
    "output_schema": {
      "type": "object",
      "required": [
        "task_id",
        "run_id",
        "quality_score",
        "standardized_records",
        "issues_summary",
        "issues_detail",
        "api_call_log",
        "lifecycle_artifacts"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "standardized_records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "raw_address",
              "std_address",
              "province",
              "city",
              "district",
              "town",
              "village",
              "lng",
              "lat",
              "address_type",
              "authenticity_result"
            ],
            "properties": {
              "record_id": {
                "type": "string"
              },
              "raw_address": {
                "type": "string"
              },
              "std_address": {
                "type": "string"
              },
              "province": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "district": {
                "type": "string"
              },
              "town": {
                "type": "string"
              },
              "village": {
                "type": "string"
              },
              "lng": {
                "type": "number"
              },
              "lat": {
                "type": "number"
              },
              "address_type": {
                "type": "string"
              },
              "authenticity_result": {
                "type": "string"
              },
              "rule_hits": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "issues_summary": {
          "type": "object",
          "properties": {
            "total_records": {
              "type": "integer"
            },
            "pass_records": {
              "type": "integer"
            },
            "fail_records": {
              "type": "integer"
            },
            "severity_counts": {
              "type": "object"
            }
          }
        },
        "issues_detail": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "record_id",
              "issue_code",
              "issue_desc",
              "severity",
              "owner"
            ],
            "properties": {
              "record_id": {
                "type": "string"
              },
              "issue_code": {
                "type": "string"
              },
              "issue_desc": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "P1",
                  "P2",
                  "P3"
                ]
              },
              "owner": {
                "type": "string"
              },
              "suggested_fix": {
                "type": "string"
              }
            }
          }
        },
        "api_call_log": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "interface_id": {
                "type": "string"
              },
              "endpoint": {
                "type": "string"
              },
              "http_status": {
                "type": "integer"
              },
              "latency_ms": {
                "type": "integer"
              }
            }
          }
        },
        "lifecycle_artifacts": {
          "type": "object",
          "properties": {
            "requirements_confirm": {
              "type": "string"
            },
            "generate": {
              "type": "string"
            },
            "dryrun": {
              "type": "string"
            },
            "publish": {
              "type": "string"
            },
            "runtime_upload": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "api_plan": {
    "registered_apis_used": [
      {
        "source_id": "fengtu",
        "interface_id": "address_standardize",
        "name": "地址标准化",
        "method": "POST"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_resolve_l5",
        "name": "五级地址解析",
        "method": "POST"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_real_check",
        "name": "地址真实性校验",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "address_type_identify",
        "name": "地址类型识别",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "geocode",
        "name": "地理编码",
        "method": "GET"
      },
      {
        "source_id": "fengtu",
        "interface_id": "reverse_geocode",
        "name": "逆地理编码",
        "method": "GET"
      }
    ],
    "missing_apis": [
      {
        "name": "高德行政区划查询",
        "endpoint": "https://restapi.amap.com/v3/config/district",
        "reason": "当前已注册接口侧重地址解析与校验，缺少权威行政区划标准码(adcode)核验能力；用于枚举合法性和省市区一致性复核",
        "requires_key": true,
        "api_key_env": "AMAP_WEB_API_KEY",
        "register_plan": {
          "target": "trust_hub",
          "tool_type": "api",
          "status_on_register": "pending_key"
        }
      }
    ]
  },
  "execution_plan": {
    "steps": [
      {
        "step_id": "S01",
        "name": "step-1",
        "stage": "custom",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S02",
        "name": "step-2",
        "stage": "custom",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S03",
        "name": "step-3",
        "stage": "custom",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      },
      {
        "step_id": "S04",
        "name": "step-4",
        "stage": "custom",
        "inputs": [],
        "outputs": [],
        "timeout_sec": 300,
        "retry": {
          "max_attempts": 1
        }
      }
    ],
    "gates": {
      "confirm_generate": false,
      "confirm_dryrun_result": false,
      "confirm_publish": false
    },
    "failure_handling": {
      "on_schema_mismatch": "continue_llm_interaction_until_valid",
      "on_api_failure": "block_error_no_fallback",
      "on_dependency_missing": "ask_user_for_key_and_register"
    }
  },
  "scripts": [
    {
      "name": "validate_contract.py",
      "purpose": "校验输入数据是否符合input_schema并检查记录数<=100",
      "runtime": "python3",
      "entry": "python scripts/validate_contract.py --input data/input.json --schema contracts/input_schema.json --out out/validated_input.json",
      "dependencies": [
        "jsonschema==4.23.0",
        "pydantic==2.8.2"
      ]
    },
    {
      "name": "run_address_governance.py",
      "purpose": "串联调用已注册Fengtu API与补齐API，执行地址标准化、解析、真实性与质量规则校验",
      "runtime": "python3",
      "entry": "python scripts/run_address_governance.py --input out/validated_input.json --output out/governance_result.json",
      "dependencies": [
        "requests==2.32.3",
        "pandas==2.2.2",
        "tenacity==8.5.0"
      ]
    },
    {
      "name": "build_publish_bundle.py",
      "purpose": "生成发布工件（标准化结果、问题清单、API日志、生命周期产物）并输出可上传包",
      "runtime": "python3",
      "entry": "python scripts/build_publish_bundle.py --result out/governance_result.json --bundle out/publish_bundle.zip",
      "dependencies": [
        "pandas==2.2.2",
        "openpyxl==3.1.5"
      ]
    },
    {
      "name": "fetch_wp_9acccd51.py",
      "purpose": "调用外部API补齐能力：高德行政区划查询",
      "runtime": "python3",
      "entry": "python scripts/fetch_wp_9acccd51.py",
      "dependencies": [
        "requests>=2.31.0"
      ]
    }
  ],
  "skills": [
    {
      "skill_id": "nanobot_workpackage_schema_orchestrator",
      "name": "nanobot 工作包协议编排",
      "path": "skills/nanobot_workpackage_schema_orchestrator.md",
      "purpose": "引导用户补齐工作包 schema 并持续收敛",
      "required": true
    },
    {
      "skill_id": "opencode_workpackage_builder_guardrails",
      "name": "opencode 工作包构建护栏",
      "path": "skills/opencode_workpackage_builder_guardrails.md",
      "purpose": "生成可执行工件并遵循 no-fallback/no-mock 约束",
      "required": true
    }
  ]
}